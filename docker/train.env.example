# electronic-lora training config — copy to `train.env` and fill in.
# Passed to the container via `docker run --env-file docker/train.env`.
# NEVER commit the filled-in train.env (it holds secrets). Only this .example.

# ---- secrets ----
WANDB_API_KEY=            # from https://wandb.ai/authorize (blank -> offline mode)
HF_TOKEN=                 # optional; only if a checkpoint repo needs auth

# ---- experiment tracking ----
WANDB_PROJECT=electronic-lora
WANDB_ENTITY=             # your W&B team/user (blank = default)
WANDB_RUN_NAME=           # blank -> auto: lokr-<variant>-e<epochs>
# WANDB_MODE=offline      # force offline; `wandb sync <dir>` uploads later

# ---- what to train ----
VARIANT=xl_base           # base | sft | xl_base | xl_sft
EPOCHS=100                # SMOKE TEST FIRST: set to 5 to measure per-epoch time
LR=0.03
LOKR_DIM=64
LOKR_ALPHA=128
SAVE_EVERY=10
SEED=42
# RESUME_FROM=/workspace/output/lokr_xl_base_v1/checkpoints/epoch_50
# EXTRA_TRAIN_ARGS=--offload-encoder   # add if XL OOMs on a 40GB A100

# ---- paths inside the container (bind-mounted; usually leave as-is) ----
# WORKDIR=/workspace
# CKPT_DIR=/workspace/checkpoints
# DATASET_DIR=/workspace/dataset
# TENSORS_DIR=/workspace/tensors_xl_base
# OUTPUT_DIR=/workspace/output/lokr_xl_base_v1
